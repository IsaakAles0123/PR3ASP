@model PR1_ASP.Models.HomeIndexViewModel
@{
    ViewData["Title"] = "Магазин кроссовок";
}

<div class="row">
    <div class="col-lg-10">
        <div class="card app-card p-4">
            <h1 class="mb-2">Кроссовки на каждый день</h1>
            <p class="app-muted mb-4">
                Учебный пример ASP.NET Core MVC с Microsoft SQL Server и Entity Framework Core: каталог товаров
                берётся из базы, корзина сохраняется в таблицах Carts/CartItems. Отдельно есть страница профиля с формой.
            </p>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" asp-controller="Catalog" asp-action="Index">Перейти в каталог</a>
                <a class="btn btn-outline-success" asp-controller="Cart" asp-action="Index">Открыть корзину</a>
                <a class="btn btn-outline-success" asp-controller="Profile" asp-action="Index">Заполнить профиль</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-10">
        <div class="d-flex align-items-end justify-content-between gap-3 mb-3">
            <div>
                <h2 class="h4 mb-1">Хитовые модели</h2>
                <div class="app-muted">Три первые позиции из каталога (те же данные из SQL Server). Полный список — в каталоге.</div>
            </div>
            <a class="btn btn-outline-success" asp-controller="Catalog" asp-action="Index">Все кроссовки</a>
        </div>

        @if (!Model.FeaturedProducts.Any())
        {
            <div class="app-muted">В базе нет товаров — сначала заполни таблицу Products.</div>
        }
        else
        {
            <partial name="_ProductCatalogCardGrid" model="Model.FeaturedProducts" />
        }
    </div>
</div>
