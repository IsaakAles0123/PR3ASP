@model PR1_ASP.Models.UserProfileDisplayViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Введённая информация";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card app-card p-4">
            <h2 class="mb-3">Отображение введённых данных</h2>

            @if (!Model.HasData || Model.Data is null)
            {
                <div class="app-muted">
                    Данные пока не сохранены. Перейдите в <a asp-controller="Profile" asp-action="Index">Профиль</a> и заполните форму.
                </div>
            }
            else
            {
                <dl class="row mb-0">
                    <dt class="col-sm-4 app-muted">Имя</dt>
                    <dd class="col-sm-8 mb-3">@Model.Data.FullName</dd>

                    <dt class="col-sm-4 app-muted">Email</dt>
                    <dd class="col-sm-8 mb-3">@Model.Data.Email</dd>

                    <dt class="col-sm-4 app-muted">Город</dt>
                    <dd class="col-sm-8 mb-3">@((string.IsNullOrWhiteSpace(Model.Data.City) ? "-" : Model.Data.City))</dd>

                    <dt class="col-sm-4 app-muted">Описание</dt>
                    <dd class="col-sm-8 mb-0">
                        <div style="white-space: pre-wrap;">@Model.Data.Bio</div>
                    </dd>
                </dl>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-light">
                        Изменить данные
                    </a>
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">
                        В каталог
                    </a>
                </div>
            }
        </div>
    </div>
</div>

