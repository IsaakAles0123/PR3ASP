@model IEnumerable<PR1_ASP.Models.ProductCatalogViewModel>

@{
    ViewData["Title"] = "Каталог";
}

<div class="row">
    <div class="col-12">
        <div class="card app-card p-4">
            <div class="d-flex flex-wrap gap-2 align-items-end justify-content-between mb-3">
                <div>
                    <h1 class="h3 mb-1">Каталог товаров</h1>
                    <div class="app-muted">Данные загружаются из Microsoft SQL Server через Entity Framework Core.</div>
                </div>
                <a class="btn btn-outline-success" asp-controller="Cart" asp-action="Index">Корзина</a>
            </div>

            @if (!Model.Any())
            {
                <div class="app-muted">В базе пока нет товаров (таблица Products пустая).</div>
            }
            else
            {
                <partial name="_ProductCatalogCardGrid" model="Model" />
            }
        </div>
    </div>
</div>
