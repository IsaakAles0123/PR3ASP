@model IEnumerable<PR1_ASP.Models.ProductCatalogViewModel>

@{
    ViewData["Title"] = "Каталог";
}

<div class="row">
    <div class="col-12">
        <div class="card app-card p-4">
            <div class="d-flex flex-wrap gap-2 align-items-end justify-content-between mb-3">
                <div>
                    <h1 class="h3 mb-1">Каталог товаров</h1>
                    <div class="app-muted">Данные загружаются из Microsoft SQL Server через Entity Framework Core.</div>
                </div>
                <a class="btn btn-outline-success" asp-controller="Cart" asp-action="Index">Корзина</a>
            </div>

            @if (!Model.Any())
            {
                <div class="app-muted">В базе пока нет товаров (таблица Products пустая).</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var p in Model)
                    {
                        <div class="col-md-4">
                            <div class="product-card h-100 d-flex flex-column">
                                <div class="product-emoji">👟</div>
                                <div class="product-title">@p.ProductName</div>
                                <div class="app-muted">Категория: @p.CategoryName</div>
                                <div class="app-muted mt-1">Наличие: @p.Stock</div>
                                <div class="mt-3 app-muted">@p.Description</div>
                                <div class="product-price mt-auto pt-3">@p.Price.ToString("0.##") ₽</div>

                                <form class="mt-3" asp-controller="Cart" asp-action="Add" method="post">
                                    <input type="hidden" name="productId" value="@p.ProductId" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-success w-100">Добавить в корзину</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
